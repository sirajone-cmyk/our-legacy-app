{
  "name": "our-legacy-app",
  "version": "1.0.0",
  "private": true,
  "description": "OUR LEGACY full-stack learning platform for madrasahs, teachers, families, and students.",
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/database"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @our-legacy/web",
    "dev:api": "npm run dev --workspace @our-legacy/api",
    "dev:all": "concurrently \"npm run dev --workspace @our-legacy/api\" \"npm run dev --workspace @our-legacy/web\"",
    "build": "npm run build --workspace @our-legacy/web && npm run build --workspace @our-legacy/api",
    "lint": "npm run lint --workspace @our-legacy/web && npm run lint --workspace @our-legacy/api",
    "db:generate": "npm run db:generate --workspace @our-legacy/database",
    "db:migrate": "npm run db:migrate --workspace @our-legacy/database",
    "db:seed": "npm run db:seed --workspace @our-legacy/database",
    "android": "npm run build --workspace @our-legacy/web && npx cap sync android && npx cap open android",
    "ios": "npm run build --workspace @our-legacy/web && npx cap sync ios && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^7.0.0"
  }
}
